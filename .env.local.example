# Copie este arquivo para .env.local e preencha com os dados do seu projeto Supabase
# (Dashboard → Project Settings → API Keys)
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-aqui

# URL pública do app (usada nos links dos e-mails)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# E-mails via Resend (opcional — sem isso o app funciona, só não envia e-mail)
# Crie a chave em https://resend.com → API Keys
RESEND_API_KEY=
# Remetente. Em teste use "Connexa <onboarding@resend.dev>".
# Com domínio verificado no Resend, use algo como "Connexa <no-reply@seudominio.com>"
EMAIL_FROM=Connexa <onboarding@resend.dev>
